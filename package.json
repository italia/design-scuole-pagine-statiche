{
  "name": "design-scuole-pagine-statiche",
  "version": "3.0.0-alpha1",
  "private": true,
  "description": "Template HTML del progetto per la realizzazione dei siti web delle Scuole Italiane",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "build:ssr": "node scripts/generate-ssr.js",
    "preview": "vite preview",
    "lint:html": "html-validate \"src/pages/**/*.html\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:css": "stylelint --fix \"src/styles/**/*.css\"",
    "lint:js": "eslint \"src/js/**/*.js\"",
    "lint:js:fix": "eslint --fix \"src/js/**/*.js\"",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "prepare": "husky install",
    "documentation-deploy-to-gh-pages": "pnpm run build && pnpm dlx gh-pages -d dist -m 'chore: update documentation' --nojekyll",
    "release:zip": "sh ./scripts/create-release-attachment.sh"
  },
  "dependencies": {
    "@italia/dev-kit-italia": "1.0.0-alpha.6",
    "package.json": "^2.0.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "extract-changelog-release": "^1.0.2",
    "fast-glob": "^3.3.3",
    "gh-pages": "^6.3.0",
    "html-validate": "^10.11.1",
    "husky": "^9.1.7",
    "linkedom": "^0.18.12",
    "lint-staged": "^16.3.3",
    "prettier": "3.5.2",
    "stylelint": "16.18.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "36.0.1",
    "stylelint-order": "8.0.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  }
}
